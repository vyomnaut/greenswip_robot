<?xml version="1.0" encoding="utf-8"?>
<robot name="ackerman_simple" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================
       GREENSWIP ACKERMAN ROBOT - COMPLETE URDF WITH IGN PLUGINS
       Robot:  4-wheel Ackerman steered, front-steer / rear-drive
       Plugins used (Ignition Gazebo / ros_gz):
         - ackermann_steering   → /cmd_ackermann  (AckermannDriveStamped)
         - camera               → /camera/image_raw
         - joint_state_publisher→ /joint_states
       Bridge topic map is in config/bridge.yaml
  ============================================================ -->

  <!-- ================= BASE ================= -->
  <link name="base_footprint"/>

  <link name="base_link">
    <inertial>
      <origin xyz="0.0115 0 0.0687" rpy="0 0 0" />
      <mass value="1.8886" />
      <inertia ixx="0.00576" ixy="0.0" ixz="0.000003"
               iyy="0.01878" iyz="0.0" izz="0.02437" />
    </inertial>
    <visual>
      <origin xyz="0.01 0 0.05" rpy="0 0 0" />
      <geometry><box size="0.35 0.15 0.08"/></geometry>
      <material name="blue"><color rgba="0.2 0.2 0.8 1" /></material>
    </visual>
    <collision>
      <origin xyz="0.01 0 0.05" rpy="0 0 0" />
      <geometry><box size="0.35 0.15 0.08"/></geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed">
    <origin xyz="-0.0117 0 0.02677" rpy="0 0 0" />
    <parent link="base_footprint" />
    <child link="base_link" />
  </joint>

  <!-- ================= FRONT LEFT STEERING & WHEEL ================= -->
  <link name="FL_STEERING_LINK">
    <inertial>
      <origin xyz="-0.0029 0 0" rpy="0 0 0" />
      <mass value="0.0038" />
      <inertia ixx="3e-7" ixy="0" ixz="0" iyy="6e-7" iyz="0" izz="3e-7" />
    </inertial>
  </link>

  <joint name="FL_STEERING_JOINT" type="revolute">
    <origin xyz="0.16174 0.085 0.0235" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="FL_STEERING_LINK" />
    <axis xyz="0 0 1" />
    <limit lower="-0.524" upper="0.524" effort="5" velocity="3" />
  </joint>

  <link name="FL_WHEEL_LINK">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.0635" />
      <inertia ixx="4.6e-5" ixy="0" ixz="0" iyy="8.9e-5" iyz="0" izz="4.6e-5" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
    </collision>
  </link>

  <joint name="FL_WHEEL_JOINT" type="continuous">
    <origin xyz="0 0.0245 0" rpy="0 0 0" />
    <parent link="FL_STEERING_LINK" />
    <child link="FL_WHEEL_LINK" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- ================= FRONT RIGHT STEERING & WHEEL ================= -->
  <link name="FR_STEERING_LINK">
    <inertial>
      <origin xyz="0.0015 0 0" rpy="0 0 0" />
      <mass value="0.0047" />
      <inertia ixx="3e-7" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="7e-7" />
    </inertial>
  </link>

  <joint name="FR_STEERING_JOINT" type="revolute">
    <origin xyz="0.16174 -0.085 0.0235" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="FR_STEERING_LINK" />
    <axis xyz="0 0 1" />
    <limit lower="-0.524" upper="0.524" effort="5" velocity="3" />
    <!-- Ackerman: inner wheel steers more than outer; plugin handles Ackerman geometry -->
  </joint>

  <link name="FR_WHEEL_LINK">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.0635" />
      <inertia ixx="4.6e-5" ixy="0" ixz="0" iyy="8.9e-5" iyz="0" izz="4.6e-5" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
    </collision>
  </link>

  <joint name="FR_WHEEL_JOINT" type="continuous">
    <origin xyz="0 -0.0245 0" rpy="0 0 0" />
    <parent link="FR_STEERING_LINK" />
    <child link="FR_WHEEL_LINK" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- ================= REAR LEFT WHEEL ================= -->
  <link name="BL_WHEEL_LINK">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.0616" />
      <inertia ixx="4.6e-5" ixy="0" ixz="0" iyy="8.9e-5" iyz="0" izz="4.6e-5" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
    </collision>
  </link>

  <joint name="BL_WHEEL_JOINT" type="continuous">
    <origin xyz="-0.13328 0.1093 0.02075" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="BL_WHEEL_LINK" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- ================= REAR RIGHT WHEEL ================= -->
  <link name="BR_WHEEL_LINK">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.0616" />
      <inertia ixx="4.6e-5" ixy="0" ixz="0" iyy="8.9e-5" iyz="0" izz="4.6e-5" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0" />
      <geometry><cylinder radius="0.05027" length="0.03"/></geometry>
    </collision>
  </link>

  <joint name="BR_WHEEL_JOINT" type="continuous">
    <origin xyz="-0.13328 -0.1093 0.02075" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="BR_WHEEL_LINK" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- ================= CAMERA LINK ================= -->
  <link name="CAMERA_LINK">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.0548" />
      <inertia ixx="6.9e-5" ixy="0" ixz="0" iyy="4e-6" iyz="0" izz="6.6e-5" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><box size="0.02 0.06 0.02"/></geometry>
      <material name="red"><color rgba="0.8 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><box size="0.02 0.06 0.02"/></geometry>
    </collision>
  </link>

  <joint name="CAMERA_JOINT" type="fixed">
    <!-- Slight downward tilt (0.1 rad) to see objects on ground in front -->
    <origin xyz="0.20 0.0 0.15" rpy="0 0.3 0" />
    <parent link="base_link" />
    <child link="CAMERA_JOINT_OPTICAL"/>
  </joint>

  <!-- Optical frame: ROS camera convention (Z forward, X right, Y down) -->
  <link name="CAMERA_JOINT_OPTICAL"/>
  <joint name="CAMERA_OPTICAL_JOINT" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
    <parent link="CAMERA_JOINT_OPTICAL"/>
    <child link="CAMERA_LINK"/>
  </joint>

  <!-- ================================================================
       GAZEBO / IGNITION PLUGINS
       All <gazebo> tags are processed by robot_state_publisher + gz_ros2_control
  ================================================================ -->

  <!-- ── 1. Ackermann Steering Controller ──────────────────────────
       Plugin: ignition-gazebo-ackermann-steering-system
       Subscribes: /cmd_ackermann  (ackermann_msgs/AckermannDriveStamped)
       Publishes:  /odom           (nav_msgs/Odometry)
                   /tf             (odom → base_footprint)
       Key geometry params (derived from URDF joint origins):
         wheel_separation  = 0.1093 * 2 = 0.2186 m
         front_wheel_track = 0.085  * 2 = 0.17   m  (FL/FR steering origin Y)
         wheelbase         = 0.16174 + 0.13328 = 0.295 m
         wheel_radius      = 0.05027 m
  ──────────────────────────────────────────────────────────────── -->
  <gazebo>
    <plugin filename="libignition-gazebo-ackermann-steering-system.so"
            name="ignition::gazebo::systems::AckermannSteering">
      <left_joint>FL_WHEEL_JOINT</left_joint>
      <right_joint>FR_WHEEL_JOINT</right_joint>
      <left_steering_joint>FL_STEERING_JOINT</left_steering_joint>
      <right_steering_joint>FR_STEERING_JOINT</right_steering_joint>
      <kingpin_width>0.17</kingpin_width>          <!-- front track width  -->
      <steering_limit>0.524</steering_limit>        <!-- ~30° max steer     -->
      <wheel_base>0.295</wheel_base>
      <wheel_separation>0.2186</wheel_separation>   <!-- rear track width   -->
      <wheel_radius>0.05027</wheel_radius>
      <min_velocity>-1.0</min_velocity>
      <max_velocity>2.0</max_velocity>
      <min_acceleration>-3</min_acceleration>
      <max_acceleration>3</max_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>
  </gazebo>

  <!-- ── 2. Camera Sensor ──────────────────────────────────────────
       Publishes: /camera/image_raw  (sensor_msgs/Image)
                  /camera/camera_info
  ──────────────────────────────────────────────────────────────── -->
  <gazebo reference="CAMERA_JOINT_OPTICAL">
    <sensor name="camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>/camera/image_raw</topic>
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov>  <!-- 80 deg -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>15.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <plugin filename="libignition-gazebo-sensors-system.so"
              name="ignition::gazebo::systems::Sensors">
        <render_engine>ogre</render_engine>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ── 3. Joint State Publisher ─────────────────────────────────
       Publishes all joint positions → /joint_states
  ──────────────────────────────────────────────────────────────── -->
  <gazebo>
    <plugin filename="libignition-gazebo-joint-state-publisher-system.so"
            name="ignition::gazebo::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

</robot>
